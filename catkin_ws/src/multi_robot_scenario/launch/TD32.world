<?xml version="1.0"?>
<sdf version="1.6">
  <world name="10m_safe_world">

    <!-- 物理引擎配置（新增） -->
    <physics type="ode">
      <max_step_size>0.01</max_step_size>
      <real_time_update_rate>100</real_time_update_rate>
    </physics>

    <!-- 光照 -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- 地面 10m×10m（添加摩擦参数） -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>10 10</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>10 10</size>
            </plane>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Grey</name>
            </script>
          </material>
        </visual>
      </link>
    </model>

    <!-- 木质围墙（添加摩擦参数） -->
    <model name="fence">
      <static>true</static>
      <link name="link">
        <!-- 北墙 -->
        <collision name="n">
          <pose>0 5 0.5 0 0 0</pose>
          <geometry><box><size>10 0.2 1</size></box></geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="nv">
          <pose>0 5 0.5 0 0 0</pose>
          <geometry><box><size>10 0.2 1</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
          </material>
        </visual>

        <!-- 南墙 -->
        <collision name="s">
          <pose>0 -5 0.5 0 0 0</pose>
          <geometry><box><size>10 0.2 1</size></box></geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="sv">
          <pose>0 -5 0.5 0 0 0</pose>
          <geometry><box><size>10 0.2 1</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
          </material>
        </visual>

        <!-- 东墙 -->
        <collision name="e">
          <pose>5 0 0.5 0 0 0</pose>
          <geometry><box><size>0.2 10 1</size></box></geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="ev">
          <pose>5 0 0.5 0 0 0</pose>
          <geometry><box><size>0.2 10 1</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
          </material>
        </visual>

        <!-- 西墙 -->
        <collision name="w">
          <pose>-5 0 0.5 0 0 0</pose>
          <geometry><box><size>0.2 10 1</size></box></geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="wv">
          <pose>-5 0 0.5 0 0 0</pose>
          <geometry><box><size>0.2 10 1</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
          </material>
        </visual>
      </link>
    </model>

