    <!-- ===================== 白色十字架墙体（新增） ===================== -->
    <model name="cross_wall">
      <static>true</static>
      <!-- 放置在第二象限，中心 (-2.5, 2.5) 地面处 -->
      <pose>-1.5 1.0 0.0 0 0 0</pose>
      <link name="link">
        <!-- 水平臂（沿 X 方向） -->
        <collision name="horizontal_collision">
          <pose>0 0 0.5 0 0 0</pose>
          <geometry><box><size>2.0 0.2 1.0</size></box></geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="horizontal_visual">
          <pose>0 0 0.5 0 0 0</pose>
          <geometry><box><size>2.0 0.2 1.0</size></box></geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>

        <!-- 垂直臂（沿 Y 方向） -->
