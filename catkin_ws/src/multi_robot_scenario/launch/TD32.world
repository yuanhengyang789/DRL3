    <!-- 沙发（添加摩擦，并补全坐垫碰撞体） -->
    <model name="sofa2">
      <static>true</static>
      <pose>0.0 4.0 0.3 0 0 1.57</pose>
      <link name="link">
        <collision name="base_collision">
